\@writefile{toc}{\contentsline {subsection}{\numberline {1.1.3}Anisotropie della Radiazione Cosmica di Fondo (CMB)}{7}{subsection.1.1.3}\protected@file@percent }
\newlabel{subsec:cmb}{{1.1.3}{7}{Anisotropie della Radiazione Cosmica di Fondo (CMB)}{subsection.1.1.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.3}{\ignorespaces Spettro di potenza delle anisotropie di temperatura della CMB in funzione della scala angolare (momenti di multipolo). La linea continua mostra l'andamento teorico del modello $\Lambda \text  {CDM}$, mentre i punti rappresentano i dati sperimentali. I dati provengono dalle sonde WMAP (2006), ACBAR (2004), BOOMERanG (2005), CBI (2004) e VSA (2004).}}{8}{figure.caption.7}\protected@file@percent }
\newlabel{fig:PowerSpectrum}{{1.3}{8}{Spettro di potenza delle anisotropie di temperatura della CMB in funzione della scala angolare (momenti di multipolo). La linea continua mostra l'andamento teorico del modello $\Lambda \text {CDM}$, mentre i punti rappresentano i dati sperimentali. I dati provengono dalle sonde WMAP (2006), ACBAR (2004), BOOMERanG (2005), CBI (2004) e VSA (2004)}{figure.caption.7}{}}
\abx@aux@cite{0}{Planck2018Overview}
\abx@aux@segm{0}{0}{Planck2018Overview}
\abx@aux@cite{0}{Planck2018Overview}
\abx@aux@segm{0}{0}{Planck2018Overview}
\@writefile{lof}{\contentsline {figure}{\numberline {1.4}{\ignorespaces Mappa delle anisotropie di temperatura della radiazione cosmica di fondo ricostruita con i dati del satellite Planck. La CMB si comporta come un corpo nero con una temperatura media di $2.725\text  { K}$, presentando minime deviazioni da un emettitore perfetto. Tali deviazioni si manifestano come fluttuazioni termiche dell'ordine di circa $\pm 300\ \mu \text  {K}$ (con variazioni medie di circa $18\ \mu \text  {K}$), le quali riflettono le anisotropie primordiali della densità di materia. Immagine tratta da \blx@tocontentsinit {0}\cite {Planck2018Overview}.}}{9}{figure.caption.8}\protected@file@percent }
\newlabel{fig:CMB}{{1.4}{9}{Mappa delle anisotropie di temperatura della radiazione cosmica di fondo ricostruita con i dati del satellite Planck. La CMB si comporta come un corpo nero con una temperatura media di $2.725\text { K}$, presentando minime deviazioni da un emettitore perfetto. Tali deviazioni si manifestano come fluttuazioni termiche dell'ordine di circa $\pm 300\ \mu \text {K}$ (con variazioni medie di circa $18\ \mu \text {K}$), le quali riflettono le anisotropie primordiali della densità di materia. Immagine tratta da \cite {Planck2018Overview}}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {section}{\numberline {1.2}Possibili candidati di Materia Oscura}{9}{section.1.2}\protected@file@percent }
\newlabel{sec:candidati}{{1.2}{9}{Possibili candidati di Materia Oscura}{section.1.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1.5}{\ignorespaces Confronto cinematico tra i meccanismi di produzione termica (\textit  {freeze-out}, linee continue a destra) e non termica (\textit  {freeze-in}, linee tratteggiate a sinistra) in funzione del parametro evolutivo $x = m_\chi / T$. La linea grigia orizzontale indica il valore della densità relitta misurato dal satellite Planck ($\Omega _{\chi } h^2 \approx 0.12$). Nel \textit  {freeze-out}, le curve deviano dall'abbondanza di equilibrio termico a seconda della sezione d'urto di annichilazione. La linea verde, che fitta perfettamente i dati di Planck, corrisponde al valore ideale dell'interazione debole ($\sim 10^{-26} \text  { cm}^3\text  {s}^{-1}$, il \textit  {WIMP miracle}). Nel \textit  {freeze-in}, l'abbondanza parte da zero e cresce per rari urti termici fino a stabilizzarsi; la linea verde tratteggiata rappresenta il valore di sezione d'urto di produzione necessario a riprodurre correttamente la densità di materia oscura attuale ($\sim 10^{-47} \text  { cm}^3\text  {s}^{-1}$, impossibile da rilevare in esperimenti come CRESST).}}{11}{figure.caption.9}\protected@file@percent }
\newlabel{fig:freeze_in_out}{{1.5}{11}{Confronto cinematico tra i meccanismi di produzione termica (\textit {freeze-out}, linee continue a destra) e non termica (\textit {freeze-in}, linee tratteggiate a sinistra) in funzione del parametro evolutivo $x = m_\chi / T$. La linea grigia orizzontale indica il valore della densità relitta misurato dal satellite Planck ($\Omega _{\chi } h^2 \approx 0.12$). Nel \textit {freeze-out}, le curve deviano dall'abbondanza di equilibrio termico a seconda della sezione d'urto di annichilazione. La linea verde, che fitta perfettamente i dati di Planck, corrisponde al valore ideale dell'interazione debole ($\sim 10^{-26} \text { cm}^3\text {s}^{-1}$, il \textit {WIMP miracle}). Nel \textit {freeze-in}, l'abbondanza parte da zero e cresce per rari urti termici fino a stabilizzarsi; la linea verde tratteggiata rappresenta il valore di sezione d'urto di produzione necessario a riprodurre correttamente la densità di materia oscura attuale ($\sim 10^{-47} \text { cm}^3\text {s}^{-1}$, impossibile da rilevare in esperimenti come CRESST)}{figure.caption.9}{}}
